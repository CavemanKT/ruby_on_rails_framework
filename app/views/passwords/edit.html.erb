<div class="max-w-md mx-auto">
  <!-- Flash 消息 -->
  <% if flash[:alert] %>
    <div class="flex items-center p-4 mb-4 text-sm text-red-800 rounded-lg bg-red-50 dark:bg-gray-800 dark:text-red-400" role="alert">
      <svg class="flex-shrink-0 inline w-4 h-4 me-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
        <path d="M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5ZM9.5 4a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3ZM12 15H8a1 1 0 0 1 0-2h1v-3H8a1 1 0 0 1 0-2h2a1 1 0 0 1 1 1v4h1a1 1 0 0 1 0 2Z"/>
      </svg>
      <%= flash[:alert] %>
    </div>
  <% end %>
  
  <% if flash[:notice] %>
    <div class="flex items-center p-4 mb-4 text-sm text-green-800 rounded-lg bg-green-50 dark:bg-gray-800 dark:text-green-400" role="alert">
      <svg class="flex-shrink-0 inline w-4 h-4 me-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
        <path d="M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5ZM9.5 4a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3ZM12 15H8a1 1 0 0 1 0-2h1v-3H8a1 1 0 0 1 0-2h2a1 1 0 0 1 1 1v4h1a1 1 0 0 1 0 2Z"/>
      </svg>
      <%= flash[:notice] %>
    </div>
  <% end %>

  <!-- 更新密码表单 -->
  <div class="bg-white shadow-md rounded-lg px-8 pt-6 pb-8 mb-4 dark:bg-gray-800 dark:border dark:border-gray-700">
    <!-- 标题和说明 -->
    <div class="mb-6">
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">Update your password</h1>
      <p class="text-sm text-gray-500 dark:text-gray-400">
        Choose a strong password with at least 8 characters.
      </p>
    </div>
    
    <%= form_with url: password_path(params[:token]), method: :put, class: "space-y-4" do |form| %>
      <!-- 新密码输入框（带可见性切换） -->
      <div>
        <%= form.label :password, "New Password", class: "block mb-2 text-sm font-medium text-gray-900 dark:text-white" %>
        <div class="relative">
          <%= form.password_field :password, 
              id: "new-password-input",
              required: true, 
              autocomplete: "new-password", 
              placeholder: "Enter new password", 
              maxlength: 72,
              class: "bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 pr-10 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500" %>
          
          <!-- 密码可见性切换按钮 -->
          <button type="button" 
                  id="toggle-new-password" 
                  class="absolute inset-y-0 end-0 flex items-center pe-3 cursor-pointer">
            <svg id="new-eye-icon" class="w-5 h-5 text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 20 14">
              <g stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
                <path d="M10 10a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z"/>
                <path d="M10 13c4.97 0 9-2.686 9-6s-4.03-6-9-6-9 2.686-9 6 4.03 6 9 6Z"/>
              </g>
            </svg>
            <svg id="new-eye-slash-icon" class="hidden w-5 h-5 text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 20 18">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1.933 10.909A4.357 4.357 0 0 1 1 9c0-1 4-6 9-6m7.6 3.8A5.068 5.068 0 0 1 19 9c0 1-3 6-9 6-.314 0-.62-.014-.918-.04M2 17 18 1m-5 8a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
            </svg>
          </button>
        </div>
      </div>
      
      <!-- 确认密码输入框（带可见性切换） -->
      <div>
        <%= form.label :password_confirmation, "Confirm New Password", class: "block mb-2 text-sm font-medium text-gray-900 dark:text-white" %>
        <div class="relative">
          <%= form.password_field :password_confirmation, 
              id: "confirm-password-input",
              required: true, 
              autocomplete: "new-password", 
              placeholder: "Repeat new password", 
              maxlength: 72,
              class: "bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 pr-10 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500" %>
          
          <!-- 密码可见性切换按钮 -->
          <button type="button" 
                  id="toggle-confirm-password" 
                  class="absolute inset-y-0 end-0 flex items-center pe-3 cursor-pointer">
            <svg id="confirm-eye-icon" class="w-5 h-5 text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 20 14">
              <g stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
                <path d="M10 10a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z"/>
                <path d="M10 13c4.97 0 9-2.686 9-6s-4.03-6-9-6-9 2.686-9 6 4.03 6 9 6Z"/>
              </g>
            </svg>
            <svg id="confirm-eye-slash-icon" class="hidden w-5 h-5 text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 20 18">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1.933 10.909A4.357 4.357 0 0 1 1 9c0-1 4-6 9-6m7.6 3.8A5.068 5.068 0 0 1 19 9c0 1-3 6-9 6-.314 0-.62-.014-.918-.04M2 17 18 1m-5 8a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
            </svg>
          </button>
        </div>
      </div>
      
      <!-- 提交按钮 -->
      <%= form.submit "Update Password", 
          class: "w-full text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800" %>
    <% end %>
    
    <!-- 返回登录链接 -->
    <div class="mt-4 text-center">
      <%= link_to "← Back to Sign In", new_session_path, 
          class: "text-sm font-medium text-blue-600 hover:underline dark:text-blue-500" %>
    </div>
  </div>

  <!-- 密码强度提示 -->
  <div class="p-4 mb-4 text-sm text-gray-800 rounded-lg bg-gray-50 dark:bg-gray-800 dark:text-gray-300" role="alert">
    <div class="font-medium mb-2">Password requirements:</div>
    <ul class="list-disc list-inside space-y-1 text-xs">
      <li>At least 8 characters long</li>
      <li>Mix of uppercase and lowercase letters recommended</li>
      <li>Include numbers and special characters for better security</li>
    </ul>
  </div>
</div>

<!-- 密码可见性切换 JavaScript -->
<script>
  document.addEventListener('turbo:load', function() {
    // 新密码切换
    const toggleNewPassword = document.getElementById('toggle-new-password');
    const newPasswordInput = document.getElementById('new-password-input');
    const newEyeIcon = document.getElementById('new-eye-icon');
    const newEyeSlashIcon = document.getElementById('new-eye-slash-icon');
    
    if (toggleNewPassword && newPasswordInput) {
      toggleNewPassword.addEventListener('click', function() {
        const type = newPasswordInput.getAttribute('type') === 'password' ? 'text' : 'password';
        newPasswordInput.setAttribute('type', type);
        newEyeIcon.classList.toggle('hidden');
        newEyeSlashIcon.classList.toggle('hidden');
      });
    }
    
    // 确认密码切换
    const toggleConfirmPassword = document.getElementById('toggle-confirm-password');
    const confirmPasswordInput = document.getElementById('confirm-password-input');
    const confirmEyeIcon = document.getElementById('confirm-eye-icon');
    const confirmEyeSlashIcon = document.getElementById('confirm-eye-slash-icon');
    
    if (toggleConfirmPassword && confirmPasswordInput) {
      toggleConfirmPassword.addEventListener('click', function() {
        const type = confirmPasswordInput.getAttribute('type') === 'password' ? 'text' : 'password';
        confirmPasswordInput.setAttribute('type', type);
        confirmEyeIcon.classList.toggle('hidden');
        confirmEyeSlashIcon.classList.toggle('hidden');
      });
    }
  });
</script>