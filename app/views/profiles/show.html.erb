<div class="min-h-screen bg-gray-50 py-12">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="bg-white shadow rounded-lg overflow-hidden">
      <div class="bg-gradient-to-r from-blue-500 to-indigo-600 px-6 py-8">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <img class="h-24 w-24 rounded-full border-4 border-white shadow-lg" 
                 src="<%= @user.avatar %>" 
                 alt="<%= @user.display_nickname %> avatar">
          </div>
          <div class="ml-6">
            <h1 class="text-3xl font-bold text-white"><%= @user.display_nickname %></h1>
            <p class="text-blue-100 mt-1">
              <% if @user.nickname.present? %>
                <%= @user.full_name if @user.full_name.present? %>
              <% else %>
                Member since <%= @user.created_at.strftime("%B %Y") %>
              <% end %>
            </p>
            <div class="mt-3 flex items-center">
              <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-800">
                🧘 <%= @user.calm_points %> Calm Points
              </span>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Profile Content -->
      <div class="px-6 py-6">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
          <!-- Main Info -->
          <div class="lg:col-span-2 space-y-6">
            <!-- About Section -->
            <div>
              <h2 class="text-xl font-semibold text-gray-900 mb-3">About</h2>
              <% if @user.bio.present? %>
                <p class="text-gray-700 leading-relaxed"><%= @user.bio %></p>
              <% else %>
                <p class="text-gray-500 italic">No bio provided yet</p>
              <% end %>
            </div>
            
            <!-- Contact Information -->
            <div>
              <h2 class="text-xl font-semibold text-gray-900 mb-3">Contact Information</h2>
              <div class="space-y-2">
                <div class="flex items-center">
                  <svg class="h-5 w-5 text-gray-400 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                  </svg>
                  <span class="text-gray-700"><%= @user.email_address %></span>
                </div>
                <% if @user.tel.present? %>
                  <div class="flex items-center">
                    <svg class="h-5 w-5 text-gray-400 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                    </svg>
                    <span class="text-gray-700"><%= @user.formatted_tel %></span>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
          
          <!-- Sidebar -->
          <div class="space-y-6">
            <!-- Stats -->
            <div class="bg-blue-50 rounded-lg p-4">
              <h3 class="text-lg font-semibold text-gray-900 mb-3">Stats</h3>
              <div class="space-y-3">
                <div class="flex justify-between">
                  <span class="text-gray-600">Member since</span>
                  <span class="font-medium"><%= @user.created_at.strftime("%B %d, %Y") %></span>
                </div>
                <div class="flex justify-between">
                  <span class="text-gray-600">Calm Points</span>
                  <span class="font-medium text-blue-600"><%= @user.calm_points %></span>
                </div>
                <div class="flex justify-between">
                  <span class="text-gray-600">Role</span>
                  <span class="font-medium">
                    <% if @user.admin? %>
                      <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
                        Admin
                      </span>
                    <% else %>
                      <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                        Member
                      </span>
                    <% end %>
                  </span>
                </div>
              </div>
            </div>
            
            <!-- Actions -->
            <div class="bg-white border border-gray-200 rounded-lg p-4">
              <h3 class="text-lg font-semibold text-gray-900 mb-3">Actions</h3>
              <div class="space-y-2">
                <%= link_to "Edit Profile", edit_profile_path, 
                    class: "block w-full text-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
                
                <% unless @user.admin? %>
                  <%= link_to "View Activity", "#", 
                      class: "block w-full text-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
