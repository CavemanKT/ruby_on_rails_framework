<% content_for :title, "Users" %>

<div class="mb-4">
  <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Users Management</h1>
  <p class="text-gray-600 dark:text-gray-400">Manage all users in the system</p>
</div>

<!-- Stats -->
<div class="grid grid-cols-1 gap-4 mb-4 md:grid-cols-3">
  <div class="p-4 bg-white border border-gray-200 rounded-lg shadow dark:bg-gray-800 dark:border-gray-700">
    <p class="text-sm text-gray-600 dark:text-gray-400">Total Users</p>
    <p class="text-2xl font-bold text-gray-900 dark:text-white"><%= @total_users %></p>
  </div>
  <div class="p-4 bg-white border border-gray-200 rounded-lg shadow dark:bg-gray-800 dark:border-gray-700">
    <p class="text-sm text-gray-600 dark:text-gray-400">Admins</p>
    <p class="text-2xl font-bold text-gray-900 dark:text-white"><%= @admins_count %></p>
  </div>
  <div class="p-4 bg-white border border-gray-200 rounded-lg shadow dark:bg-gray-800 dark:border-gray-700">
    <p class="text-sm text-gray-600 dark:text-gray-400">Banned Users</p>
    <p class="text-2xl font-bold text-gray-900 dark:text-white"><%= @banned_users_count %></p>
  </div>
</div>

<!-- Users list -->
<div class="p-6 bg-white border border-gray-200 rounded-lg shadow dark:bg-gray-800 dark:border-gray-700">
  <h5 class="mb-2 text-xl font-bold text-gray-900 dark:text-white">Users List</h5>
  <p class="text-gray-700 dark:text-gray-400">
    User management features are coming soon.
  </p>
</div>

