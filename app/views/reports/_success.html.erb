<div id="report_modal" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
  <div class="bg-white rounded-lg shadow-xl max-w-md w-full mx-4">
    <div class="px-6 py-8 text-center">
      <!-- 成功图标 -->
      <div class="mx-auto h-12 w-12 bg-green-100 rounded-full flex items-center justify-center mb-4">
        <svg class="h-6 w-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
        </svg>
      </div>
      
      <h3 class="text-lg font-semibold text-gray-900 mb-2">Report Submitted</h3>
      <p class="text-sm text-gray-600 mb-6">
        Thank you for helping keep our community safe. We'll review your report and take appropriate action.
      </p>
      
      <button type="button" 
              data-action="click->modal#close"
              class="w-full px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
        Close
      </button>
    </div>
  </div>
</div>
