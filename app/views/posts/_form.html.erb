<div id="new_post_form" class="bg-white rounded-lg shadow-md p-6 mb-6">
  <div class="flex items-start space-x-4">
    <!-- 用户头像 -->
    <div class="flex-shrink-0">
      <img class="h-10 w-10 rounded-full" 
           src="<%= current_user.avatar %>" 
           alt="<%= current_user.display_nickname %> avatar">
    </div>
    
    <!-- 表单内容 -->
    <div class="flex-1">
      <%= form_with(model: @post || Post.new, local: true, class: "space-y-4") do |form| %>
        <!-- 内容输入框 -->
        <div>
          <%= form.text_area :content, 
              placeholder: "What's on your mind? Share your thoughts, feelings, or experiences...",
              rows: 4,
              class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm",
              data: { 
                controller: "character-count",
                character_count_target: "input",
                action: "input->character-count#update"
              } %>
          <% if @post && @post.errors[:content].any? %>
            <p class="mt-1 text-sm text-red-600"><%= @post.errors[:content].first %></p>
          <% end %>
          <div class="mt-1 flex justify-between text-sm text-gray-500">
            <span>Use #hashtags to categorize your post</span>
            <span data-character-count-target="counter">0 / 5000</span>
          </div>
        </div>
        
        <!-- 可见性选择 -->
        <div>
          <%= form.label :visibility, "Who can see this post?", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <div class="flex space-x-4">
            <div class="flex items-center">
              <%= form.radio_button :visibility, :public_post, class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300" %>
              <%= form.label :visibility_public_post, "Public", class: "ml-2 text-sm text-gray-700" %>
              <span class="ml-1 text-xs text-gray-500">Everyone can see</span>
            </div>
            <div class="flex items-center">
              <%= form.radio_button :visibility, :circle, class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300" %>
              <%= form.label :visibility_circle, "Support Circle", class: "ml-2 text-sm text-gray-700" %>
              <span class="ml-1 text-xs text-gray-500">Only your support circle</span>
            </div>
            <div class="flex items-center">
              <%= form.radio_button :visibility, :private_post, class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300" %>
              <%= form.label :visibility_private_post, "Private", class: "ml-2 text-sm text-gray-700" %>
              <span class="ml-1 text-xs text-gray-500">Only you can see</span>
            </div>
          </div>
        </div>
        
        <!-- 提交按钮 -->
        <div class="flex justify-end">
          <%= form.submit "Share Post", 
              class: "px-6 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
