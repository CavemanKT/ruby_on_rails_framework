    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-gray-900">Share Your Thoughts</h1>
      <p class="mt-2 text-gray-600">Express yourself and connect with the community</p>
    </div>
    
    <%= render 'posts/form', post: @post %>
    
    <div class="mt-6">
      <%= link_to "← Back to Home", home_index_path, 
