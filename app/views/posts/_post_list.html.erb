<% if posts.any? %>
  <% posts.each do |post| %>
    <%= render 'posts/post', post: post %>
  <% end %>
  
  <!-- 加载更多按钮 -->
  <div class="text-center py-4">
    <%= link_to "Load More", posts_path(page: (params[:page] || 1).to_i + 1), 
        class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2",
        data: { turbo_frame: "posts_list" } %>
  </div>
<% else %>
  <div class="text-center py-12">
    <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
    </svg>
    <h3 class="mt-2 text-sm font-medium text-gray-900">No posts yet</h3>
    <p class="mt-1 text-sm text-gray-500">Be the first to share something with the community!</p>
  </div>
<% end %>
