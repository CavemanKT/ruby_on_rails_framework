<div id="comment_<%= comment.id %>" class="flex space-x-3 mb-4">
  <img class="h-8 w-8 rounded-full flex-shrink-0" 
       src="<%= comment.user.avatar %>" 
       alt="<%= comment.user.display_nickname %> avatar">
  
  <div class="flex-1">
    <div class="bg-gray-50 rounded-lg px-4 py-2">
      <!-- 评论头部 -->
      <div class="flex items-center justify-between mb-1">
        <div class="flex items-center space-x-2">
          <span class="text-sm font-medium text-gray-900">
            <%= link_to comment.user.display_nickname, profile_path, class: "hover:text-blue-600" %>
          </span>
          <span class="text-xs text-gray-500">
            <%= time_ago_in_words(comment.created_at) %> ago
          </span>
        </div>
        
        <!-- 评论操作菜单 -->
        <% if comment.user == current_user %>
          <div class="relative" data-controller="dropdown">
            <button type="button" 
                    data-action="click->dropdown#toggle"
                    class="p-1 rounded-full hover:bg-gray-200 focus:outline-none focus:ring-2 focus:ring-blue-500">
              <svg class="h-4 w-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z"></path>
              </svg>
            </button>
            
            <div data-dropdown-target="menu" 
                 class="hidden absolute right-0 mt-2 w-32 bg-white rounded-md shadow-lg py-1 z-10">
              <%= link_to "Edit", edit_post_comment_path(comment.post, comment), 
                  class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
              <%= link_to "Delete", post_comment_path(comment.post, comment), 
                  method: :delete,
                  data: { 
                    confirm: "Are you sure you want to delete this comment?",
                    turbo_method: :delete
                  },
                  class: "block px-4 py-2 text-sm text-red-700 hover:bg-red-50" %>
            </div>
          </div>
        <% end %>
      </div>
      
      <!-- 评论内容 -->
      <p class="text-sm text-gray-700 whitespace-pre-wrap"><%= comment.content %></p>
    </div>
  </div>
</div>
