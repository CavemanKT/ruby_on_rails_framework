#!/bin/bash
set -e

echo "Starting Docker entrypoint..."

# 等待 PostgreSQL 就绪
echo "Waiting for PostgreSQL to be ready..."
until pg_isready -h "$DB_HOST" -p 5432 -U "$DB_USERNAME" -d "$DB_NAME"; do
  echo "PostgreSQL is unavailable - sleeping"
  sleep 2
done

echo "PostgreSQL is ready!"

# 检查数据库是否存在，如果不存在则创建
echo "Checking if database exists..."
if ! psql -h "$DB_HOST" -U "$DB_USERNAME" -d "$DB_NAME" -c '\q' 2>/dev/null; then
  echo "Database does not exist, creating..."
  createdb -h "$DB_HOST" -U "$DB_USERNAME" "$DB_NAME"
fi

# 运行数据库迁移
echo "Running database migrations..."
bin/rails db:migrate

# 导入数据（如果存在导出文件）
if [ -f "tmp/users_export.json" ]; then
  echo "Importing data from SQLite export..."
  bin/rails data:import
fi

echo "Database setup completed!"

# 执行主命令
exec "$@"